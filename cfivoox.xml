<?xml version="1.0" encoding="utf-8" ?>
<extension type="plugin" group="fields" method="upgrade">
	<name>plg_fields_cfivoox</name>
	<author>Sergio Iglesias</author>
	<creationDate>June 2026</creationDate>
	<copyright>Copyright 2023 - SergioIglesiasNET.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>info@sergioiglesias.net</authorEmail>
	<authorUrl>https://sergioiglesias.net</authorUrl>
	<version>2.0.0</version>
	<description>PLG_FIELDS_CFIVOOX_XML_DESCRIPTION</description>
	<namespace path="src">SergioIglesias\Plugin\Fields\Cfivoox</namespace>
	<files>
		<filename plugin="cfivoox">cfivoox.php</filename>
		<folder>services</folder>
		<folder>src</folder>
		<folder>params</folder>
		<folder>tmpl</folder>
	</files>
	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.plg_fields_cfivoox.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_fields_cfivoox.sys.ini</language>
		<language tag="es-ES">es-ES/es-ES.plg_fields_cfivoox.ini</language>
		<language tag="es-ES">es-ES/es-ES.plg_fields_cfivoox.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="default_colorivoox"
					type="color"
					default="ff6600"
					label="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_COLOR_LABEL"
					description="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_COLOR_DESCRIPTION"
				/>
				<field
					name="default_player"
					type="list"
					default="default"
					label="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_PLAYER_LABEL"
					description="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_PLAYER_DESCRIPTION"
				>
					<option value="default">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_DEFAULT</option>
					<option value="html5">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_HTML5</option>
					<option value="html5mini">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_HTML5MINI</option>
					<option value="simplelink">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_SIMPLELINK</option>
				</field>
				<field
					name="default_tag_player"
					type="list"
					default="default"
					label="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_TAG_PLAYER_LABEL"
					description="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_TAG_PLAYER_DESCRIPTION"
				>
					<option value="default">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_DEFAULT</option>
					<option value="html5">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_HTML5</option>
					<option value="html5mini">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_HTML5MINI</option>
					<option value="simplelink">PLG_FIELDS_CFIVOOX_PARAMS_PLAYER_OPTION_SIMPLELINK</option>
				</field>
				<field
					name="default_tag_colorivoox"
					type="color"
					default=""
					label="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_TAG_COLOR_LABEL"
					description="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_TAG_COLOR_DESCRIPTION"
				/>
				<field
					name="default_display"
					type="list"
					default="3"
					label="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_LABEL"
					description="PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_DESCRIPTION"
				>
					<option value="1">PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_OPTION_AFTER_TITLE</option>
					<option value="2">PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_OPTION_BEFORE_CONTENT</option>
					<option value="3">PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_OPTION_AFTER_CONTENT</option>
					<option value="0">PLG_FIELDS_CFIVOOX_PARAMS_DEFAULT_DISPLAY_OPTION_MANUAL</option>
				</field>
			</fieldset>
		</fields>
	</config>
</extension>
